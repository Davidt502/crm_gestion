# ─── Copia este archivo como .env y completa los valores ───
# NUNCA subas .env a git. Asegúrate que está en .gitignore.

# Base de datos SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=crm_ing_software
DB_USER=tu_usuario_aqui
DB_PASSWORD=tu_password_aqui

# JWT: genera una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZA_ESTO_CON_UNA_CLAVE_SECRETA_SEGURA_DE_64_CHARS

# Flask
FLASK_DEBUG=false

# JWT expiry en horas
JWT_EXPIRY_HOURS=8

# CORS - separa múltiples orígenes con coma
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Google OAuth ───────────────────────────────────────────
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto → APIs y servicios → Credenciales
# 3. Crea "ID de cliente OAuth 2.0" tipo "Aplicación web"
# 4. En "Orígenes autorizados" agrega tu dominio/localhost
# 5. Copia el CLIENT_ID aquí y en frontend/login.html
GOOGLE_CLIENT_ID=
75631802295-15mclu3sb64l0mkrtr3m7ptgsr4qkj5r.apps.googleusercontent.com
